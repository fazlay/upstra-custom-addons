<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="purchase_order_form_inherit_spacer" model="ir.ui.view">
        <field name="name">purchase.order.view.form.inherit.spacer</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="digital_signature.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='purchase_signature']//field[@name='sign_by']" position="before">
                <field name="signature_spacer" options="{'safe': True}"/>
            </xpath>
        </field>
    </record>
</odoo>
