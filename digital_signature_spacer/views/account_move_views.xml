<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Inherit view_move_form from digital_signature to add signature_spacer -->
    <record id="view_move_form_inherit_spacer" model="ir.ui.view">
        <field name="name">account.move.view.form.inherit.spacer</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="digital_signature.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Invoice Digital Signature Tab (first occurrence of sign_by) -->
            <xpath expr="(//field[@name='sign_by'])[1]" position="before">
                <field name="signature_spacer" readonly="state != 'draft'" options="{'safe': True}"/>
            </xpath>
            <!-- Bill Digital Signature Tab (second occurrence of sign_by) -->
            <xpath expr="(//field[@name='sign_by'])[2]" position="before">
                <field name="signature_spacer" readonly="state != 'draft'" options="{'safe': True}"/>
            </xpath>
        </field>
    </record>
</odoo>
