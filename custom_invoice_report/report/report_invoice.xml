<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_invoice_document_inherit_custom" inherit_id="account.report_invoice_document">
        <xpath expr="//td[@name='td_subtotal']" position="replace">
            <td name="td_subtotal" class="text-end o_price_total">
                <span class="text-nowrap" t-if="line.display_subtotal_from_line" t-out="line.display_subtotal_from_line.price_subtotal" t-options="{'widget': 'monetary','display_currency':line.display_subtotal_from_line.product_id.display_currency_id or line.product_id.display_currency_id                  }"/>
                <span class="text-nowrap" t-else="" t-out="line.price_subtotal" t-options="{                       'widget': 'monetary',                       'display_currency': line.product_id.display_currency_id or o.currency_id                   }"/>
            </td>
        </xpath>
        <xpath expr="//span[@t-field='o.invoice_number']" position="after">
            <div t-if="o.show_bin" style="font-size:14px">BIN - 0010126030203</div>
        </xpath>
        <xpath expr="//p[contains(@t-if, 'o.company_id.id == 1')]" position="replace">
            <p t-if="o.show_exchange_rate">
        USD Exchange Rate: <span t-esc="o.bdt_rate"/>
            </p>
        </xpath>
        <!-- <xpath expr="//tr[td[contains(text(), 'Total (BDT):')]]" position="replace"/> -->
