                  }"/>
            </td>
        </xpath> -->

    </template>
    <template id="remove_bdt_rows_if_exist" inherit_id="account.report_invoice_document" name="Remove BDT Rows" priority="100">
        <!-- Use groups INSIDE the view, not on the template -->
        <xpath expr="//tr[td[contains(text(), 'Total (BDT):')]]" position="replace" groups="base.group_no_one"/>
        <!-- <xpath expr="//tr[@t-if='Flase']" position="replace" groups="base.group_no_one"/> -->
    </template>
