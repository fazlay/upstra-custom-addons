    <template id="invoice_upstra_custom_tax_totals" inherit_id="account.document_tax_totals_template" priority="10">
        <!-- <xpath expr="//t[contains(@t-foreach, 'tax_groups')]" position="replace"></xpath>
        <xpath expr="//t[contains(@t-foreach, 'tax_groups')]" position="replace"></xpath>
        <xpath expr="//tr[hasclass('o_subtotal')]/td[1]/span[text()='Untaxed Amount']" position="replace">

        </xpath> -->
        <!-- <xpath expr="//tr[hasclass('o_subtotal')]" position="replace"/>
        <xpath expr="//tr[hasclass('o_total')]" position="replace"> -->

        <xpath expr="." position="replace">
            <tr class="o_total">
                <td class="text-end">

                    <t t-if="o.use_custom_total ">
                        <strong>Total Amount</strong>
                    </t>

                    <t t-else="">
                        <t t-if="o.bdt_rate &lt; 1">
                            <strong>Total (BDT):</strong>
                        </t>
                        <t t-else="">
                            <strong>Total (USD):</strong>
                        </t>
                    </t>
                </td>
                <td class="text-end">
                    <t t-if="o.use_custom_total">
                        <t t-set="bdt_currency" t-value="env['res.currency'].search([('name', '=', 'BDT')], limit=1)"/>
                        <strong t-out="o.custom_total" t-options='{"widget": "monetary", "display_currency": bdt_currency}'/>
                    </t>
                    <t t-else="">
                        <strong t-out="tax_totals['total_amount_currency']" t-options='{"widget": "monetary", "display_currency": currency}'/>
                    </t>
                </td>
            </tr>
        </xpath>
    </template>
</odoo>