<!-- views/account_move_line_views.xml -->
<odoo>
    <data>
        <record id="view_invoice_line_form_inherit" model="ir.ui.view">
            <field name="name">account.move.line.form.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_line_ids']/list//field[@name='price_subtotal']" position="before">
                    <field name="line_currency_id" column_invisible="True"/>
                    <field name="display_subtotal_from_line" optional="show" string="Subtotal From" domain="[('move_id', '=', parent.id)]"/>
                </xpath>
                <xpath expr="//field[@name='invoice_line_ids']/list//field[@name='price_subtotal']" position="attributes">
                    <attribute name="options">{'currency_field': 'line_currency_id'}</attribute>
                </xpath>
                <xpath expr="//field[@name='invoice_line_ids']/list//field[@name='account_id']" position="attributes">
                    <attribute name="optional">hide</attribute>
                </xpath>
                <xpath expr="//field[@name='invoice_line_ids']/list//field[@name='region']" position="attributes">
                    <attribute name="optional">hide</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
