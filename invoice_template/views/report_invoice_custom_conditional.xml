<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_invoice_document_custom" inherit_id="account.report_invoice_document">

        <!-- ✅ Replace Quantity TH -->
        <xpath expr="//th[@name='th_quantity']" position="replace">
            <th name="th_quantity" t-if="o.quantity_column" class="text-end">
                <span>Quantity</span>
            </th>
        </xpath>

        <!-- ✅ Replace Unit Price TH -->
        <xpath expr="//th[@name='th_priceunit']" position="replace">
            <th name="th_priceunit" t-if="o.unit_price_column" t-attf-class="text-end text-nowrap {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                <span>Unit Price</span>
            </th>
        </xpath>

        <xpath expr="//td[@name='td_quantity']" position="replace">
            <td name="td_quantity" t-if="o.quantity_column" class="text-end text-nowrap">
                <span t-field="line.quantity">3.00</span>
            </td>
        </xpath>

        <xpath expr="//td[@name='td_price_unit']" position="replace">
            <td name="td_price_unit" t-if="o.unit_price_column" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                <span class="text-nowrap" t-field="line.price_unit">9.00</span>
            </td>
        </xpath>

    </template>
</odoo>