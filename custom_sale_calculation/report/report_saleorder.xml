<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="sale_upstra_custom_tax_totals" inherit_id="account.document_tax_totals_template" priority="10">
        <xpath expr="//tr[hasclass('o_total')]" position="replace">
            <tr class="o_total">
                <td class="text-end">
                    <t t-if="tax_totals.get('use_custom_total')">
                        <strong>Total Amount</strong>
                    </t>
                    <t t-else="">
                        <t t-if="currency.name == 'BDT'">
                            <strong>Total (BDT):</strong>
                        </t>
                        <t t-else="">
                            <strong>Total (USD):</strong>
                        </t>
                    </t>
                </td>
                <td class="text-end">
                    <t t-if="tax_totals.get('use_custom_total')">
                        <t t-set="bdt_currency" t-value="env['res.currency'].search([('name', '=', 'BDT')], limit=1)"/>
                        <strong t-out="tax_totals.get('custom_total')" t-options="{'widget': 'monetary', 'display_currency': bdt_currency}"/>
                    </t>
                    <t t-else="">
                        <strong t-out="tax_totals['total_amount_currency']" t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                    </t>
                </td>
            </tr>
        </xpath>
    </template>
    <template id="report_saleorder_hide_extra_bdt" inherit_id="sale_usd_to_bdt.report_saleorder_document_inherit_bdt">
        <xpath expr="//tr[td/strong[contains(text(),'Total (BDT)')]]" position="attributes">
            <attribute name="style">display:none</attribute>
        </xpath>
    </template>

    <template id="report_saleorder_line_currency" inherit_id="sale.report_saleorder_document">
        <xpath expr="//td[@name='td_subtotal']" position="replace">
            <td t-if="not line.is_downpayment" name="td_subtotal" class="text-end o_price_total">
                <span t-field="line.price_subtotal" 
                      t-options="{'widget': 'monetary', 'display_currency': line.product_id.display_currency_id or doc.currency_id}"/>
            </td>
        </xpath>
    </template>

</odoo>