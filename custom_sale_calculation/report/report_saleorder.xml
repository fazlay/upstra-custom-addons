<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_saleorder_document_inherit_custom" inherit_id="sale.report_saleorder_document">

        <xpath expr="//td[@name='td_subtotal']" position="replace">
            <td name="td_subtotal" class="text-end o_price_total">
                <span class="text-nowrap" t-if="line.display_subtotal_from_line" t-out="line.display_subtotal_from_line.price_subtotal" t-options="{'widget': 'monetary','display_currency':line.display_subtotal_from_line.product_id.display_currency_id or line.product_id.display_currency_id}"/>
                <span class="text-nowrap" t-else="" t-out="line.price_subtotal" t-options="{'widget': 'monetary', 'display_currency': line.product_id.display_currency_id or doc.currency_id}"/>
            </td>
        </xpath>

        <xpath expr="//span[@t-field='doc.name']" position="after">
            <div t-if="doc.show_bin" style="font-size:14px">BIN - 0010126030203</div>
        </xpath>

    </template>

    <template id="report_saleorder_custom_table" inherit_id="sale.report_saleorder_document">

        <xpath expr="//t[@t-set='lines_to_report']" position="replace">
            <t t-set="lines_to_report" t-value="doc.order_line.filtered(
                lambda l: not l.line_type or l.line_type in ('main_invoice_only', 'both') ).sorted(key=lambda l: (-l.sequence, l.date, l.order_id.name, -l.id), reverse=True)"/>
        </xpath>

        <xpath expr="//div[hasclass('clearfix') and @name='so_total_summary']" position="after">
            <t t-set="breakdown_lines" t-value="doc.order_line.filtered(
                lambda l: l.line_type in ('breakdown', 'both') ).sorted(key=lambda l: (-l.sequence, l.date, l.order_id.name, -l.id), reverse=True)"/>

            <div t-if="breakdown_lines and doc.print_breakdown" style="page-break-before: always;">
                <div class="page mb-4">
                    <h3>Order Breakdown</h3>
                    <table class="o_has_total_table table o_main_table table-borderless mb-0">
                        <thead>
                            <tr>
                                <th style="width: 450px;" class="text-start"><span>Product</span></th>
                                <th class="text-center"><span>Description</span></th>
                                <th class="text-center" t-if="doc.quantity_column"><span>Quantity</span></th>
                                <th class="text-center" t-if="doc.unit_price_column"><span>Unit Price</span></th>
                                <th class="text-end"><span>Amount</span></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="breakdown_lines" t-as="line">
                                <tr>
                                    <td style="width: 450px;"><span t-field="line.name"/></td>
                                    <td class="text-center"><span t-field="line.product_id.description_sale"/></td>
                                    <td t-if="doc.quantity_column" class="text-end"><span t-field="line.product_uom_qty"/></td>
                                    <td t-if="doc.unit_price_column" class="text-end"><span t-field="line.price_unit"/></td>
                                    <td class="text-end"><span t-field="line.price_subtotal" t-options="{'widget': 'monetary', 'display_currency': line.product_id.display_currency_id or doc.currency_id}"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    <div t-if="not doc.split_table_by_section" class="overflow-hidden">
                        <div class="col-6 d-inline-block float-end">
                            <table class="o_total_table table table-borderless avoid-page-break-inside">
                                <tbody>
                                    <tr class="fw-bold total">
                                        <td class="text-end">Total (BDT):</td>
                                        <td class="text-end">
                                            <t t-if="doc.use_custom_total">
                                                <t t-set="bdt_currency" t-value="env['res.currency'].search([('name', '=', 'BDT')], limit=1)"/>
                                                <strong t-out="doc.custom_total" t-options='{"widget": "monetary", "display_currency": bdt_currency}'/>
                                            </t>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>

    </template>

    <template id="report_saleorder_split_table" inherit_id="sale.report_saleorder_document">

        <xpath expr="//table[hasclass('o_main_table')]" position="attributes">
            <attribute name="t-if">not doc.split_table_by_section</attribute>
        </xpath>

        <xpath expr="//div[@id='total']" position="attributes">
            <attribute name="t-if">not doc.split_table_by_section</attribute>
        </xpath>

        <xpath expr="//table[hasclass('o_main_table')]" position="after">

            <t t-if="doc.split_table_by_section">

                <t t-set="display_discount" t-value="any(l.discount for l in doc.order_line)"/>
                <t t-set="lines" t-value="doc.order_line.filtered(
                    lambda l: not l.line_type or l.line_type in ('main_invoice_only', 'both') ).sorted(key=lambda l: (-l.sequence, l.date, l.order_id.name, -l.id), reverse=True)"/>

                <t t-set="table_groups" t-value="[]"/>
                <t t-set="current_group" t-value="[]"/>

                <t t-foreach="lines" t-as="line">
                    <t t-if="line.display_type == 'line_section'">
                        <t t-if="current_group">
                            <t t-set="table_groups" t-value="table_groups + [current_group]"/>
                        </t>
                        <t t-set="current_group" t-value="[line]"/>
                    </t>
                    <t t-else="">
                        <t t-set="current_group" t-value="current_group + [line]"/>
                    </t>
                </t>
                <t t-if="current_group">
                    <t t-set="table_groups" t-value="table_groups + [current_group]"/>
                </t>

                <t t-foreach="table_groups" t-as="group">
                    <t t-set="is_section" t-value="group and group[0].display_type == 'line_section'"/>

                    <h3 t-if="is_section and not group_last" class="mt-4 mb-2">
                        <span t-field="group[0].name"/>
                    </h3>

                    <t t-set="group_lines" t-value="group[1:] if is_section else group"/>

                    <table t-if="group_lines" class="o_has_total_table table o_main_table table-borderless mb-4" name="sale_order_table_split">
                        <thead t-if="not (is_section and group_last)">
                            <tr>
                                <th class="text-start" style="width: 450px;"><span>Product</span></th>
                                <th t-if="not (is_section and group_last)" class="text-end"><span>Description</span></th>
                                <th t-if="not (is_section and group_last)" class="text-end"><span>Quantity</span></th>
                                <th t-if="not (is_section and group_last)" class="text-end"><span>Unit Price</span></th>
                                <th t-if="display_discount and not (is_section and group_last)" class="text-end"><span>Disc.%</span></th>
                                <th class="text-end"><span>Amount</span></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="group_lines" t-as="line">
                                <tr>
                                    <td style="width: 450px;"><span t-field="line.name"/></td>
                                    <td class="text-end" style="width: 250px;"><span t-field="line.product_id.description_sale"/></td>
                                    <td class="text-end"><span t-field="line.product_uom_qty"/></td>
                                    <td class="text-end"><span t-field="line.price_unit"/></td>
                                    <td t-if="display_discount" class="text-end"><span t-field="line.discount"/></td>
                                    <td class="text-end"><span t-field="line.price_subtotal" t-options="{'widget': 'monetary', 'display_currency': line.product_id.display_currency_id or doc.currency_id}"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
            </t>
        </xpath>

    </template>

    <template id="sale_custom_tax_totals" inherit_id="sale.document_tax_totals" priority="10">
        <xpath expr="." position="replace">
            <tr class="o_total">
                <td class="text-end">
                    <t t-if="doc.use_custom_total">
                        <strong>Total Amount</strong>
                    </t>
                    <t t-else="">
                        <strong>Total:</strong>
                    </t>
                </td>
                <td class="text-end">
                    <t t-if="doc.use_custom_total">
                        <t t-set="bdt_currency" t-value="env['res.currency'].search([('name', '=', 'BDT')], limit=1)"/>
                        <strong t-out="doc.custom_total" t-options='{"widget": "monetary", "display_currency": bdt_currency}'/>
                    </t>
                    <t t-else="">
                        <strong t-out="tax_totals['total_amount_currency']" t-options='{"widget": "monetary", "display_currency": currency}'/>
                    </t>
                </td>
            </tr>
        </xpath>
    </template>

</odoo>
