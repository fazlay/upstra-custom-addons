<odoo>

    <record id="view_sale_total_type_list" model="ir.ui.view">
        <field name="name">sale.total.type.list</field>
        <field name="model">sale.total.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_sale_total_type_form" model="ir.ui.view">
        <field name="name">sale.total.type.form</field>
        <field name="model">sale.total.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="active"/>
                        <field name="total_code" widget="ace" options="{'mode': 'python'}" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sale_total_type" model="ir.actions.act_window">
        <field name="name">Sale Total Types</field>
        <field name="res_model">sale.total.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_sale_total_type" name="Sale Total Types"
        parent="sale.sale_order_menu"
        action="action_sale_total_type"
        sequence="100"/>

</odoo>
