<odoo>
    <data>

        <record id="view_sale_order_custom_calc" model="ir.ui.view">
            <field name="name">sale.order.form.custom.calc</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='partner_id']" position="after">
                    <group string="Custom Total Calculation" col="4">
                        <field name="total_type_id" placeholder="Select Total Method"/>
                    </group>
                </xpath>

                <!-- <xpath expr="//field[@name='date_order']" position="after">
                    <group string="Report Options" col="4">
                      <field name="print_breakdown" nolabel="1"/>
                        <field name="split_table_by_section" nolabel="1"/>
                      <field name="show_bin" nolabel="1"/> 
                        <field name="show_exchange_rate" nolabel="1"/>
                    </group>
                </xpath> -->

                <xpath expr="//button[@name='action_confirm']" position="before">
                    <button name="action_recalculate_custom_lines" type="object" string="Recalculate" invisible="not order_line"/>
                </xpath>

                <xpath expr="//field[@name='order_line']" position="after">
                    <group string="Custom Total Calculation" col="4">
                        <field name="use_custom_total" string="Enable Custom Total"/>
                    </group>
                </xpath>

                <xpath expr="//field[@name='amount_total_bdt']" position="attributes">
                    <attribute name="invisible">use_custom_total</attribute>
                </xpath>

                <xpath expr="//group[@name='sale_total']" position="attributes">
                    <attribute name="invisible">use_custom_total</attribute>
                </xpath>

                <xpath expr="//button[@name='action_open_discount_wizard']" position="attributes">
                    <attribute name="invisible">use_custom_total</attribute>
                </xpath>

                <xpath expr="//group[@name='note_group']" position="inside">
                    <group class="oe_subtotal_footer d-flex order-0 order-lg-1 flex-column gap-0 gap-sm-3" colspan="2" name="custom_sale_total" invisible="not use_custom_total">
                        <div class="d-flex justify-content-end align-items-center gap-3 w-100">
                            <span class="fw-bold fs-3 m-0">Total Amount</span>
                            <h1 class="m-0 fw-bold">
                                <field name="custom_total" widget="float" readonly="1" nolabel="1"/>
                            </h1>
                        </div>
                    </group>
                </xpath>

            </field>
        </record>

        <record id="sale_order_line_tree_custom" model="ir.ui.view">
            <field name="name">sale.order.line.tree.custom</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='order_line']/list//field[@name='price_subtotal']" position="before">
                    <field name="line_currency_id" invisible="1"/>
                    <field name="display_subtotal_from_line" optional="show" string="Subtotal From" domain="[('order_id', '=', parent.id)]"/>
                </xpath>
                <xpath expr="//field[@name='order_line']/list//field[@name='price_subtotal']" position="attributes">
                    <attribute name="options">{'currency_field': 'line_currency_id'}</attribute>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
