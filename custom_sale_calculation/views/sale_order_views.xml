<odoo>
    <data>

        <record id="view_sale_order_custom_calc" model="ir.ui.view">
            <field name="name">sale.order.form.custom.calc</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='partner_id']" position="after">
                    <group string="Custom Total Calculation" col="4">
                        <field name="total_type_id" placeholder="Select Total Method"/>
                    </group>
                </xpath>

                <xpath expr="//group[@name='sale_header_right']/.." position="after">
                    <group string="Report Options" col="4">
                        <label for="print_breakdown" string="Print Breakdown"/>
                        <field name="print_breakdown" widget="boolean_toggle" nolabel="1"/>
                        <label for="split_table_by_section" string="Split Table by Section"/>
                        <field name="split_table_by_section" widget="boolean_toggle" nolabel="1"/>
                        <label for="show_bin" string="Show BIN"/>
                        <field name="show_bin" widget="boolean_toggle" nolabel="1"/>
                        <label for="show_exchange_rate" string="Show Exchange Rate"/>
                        <field name="show_exchange_rate" widget="boolean_toggle" nolabel="1"/>
                    </group>
                </xpath>

                <xpath expr="//button[@name='action_confirm']" position="before">
                    <button name="action_recalculate_custom_lines" type="object" string="Recalculate" invisible="not order_line"/>
                </xpath>

                <xpath expr="//field[@name='order_line']" position="after">
                    <group string="Custom Total Calculation" col="4">
                        <field name="use_custom_total" string="Enable Custom Total"/>
                        <field name="custom_total" readonly="1" string="Calculated Total" invisible="not use_custom_total"/>
                    </group>
                </xpath>

            </field>
        </record>

        <record id="sale_order_line_tree_custom" model="ir.ui.view">
            <field name="name">sale.order.line.tree.custom</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='order_line']/list//field[@name='price_subtotal']" position="before">
                    <field name="display_subtotal_from_line" optional="show" string="Subtotal From" domain="[('order_id', '=', parent.id)]"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
