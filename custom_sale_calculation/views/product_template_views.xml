<odoo>

    <record id="product_template_form_view_inherit" model="ir.ui.view">
        <field name="name">product.template.form.inherit.sale.custom.calc</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Custom Calculation" name="custom_calc_settings">
                    <group>
                        <field name="line_type"/>
                        <field name="display_currency_id"/>
                        <field name="use_custom_calc"/>
                        <field name="custom_calc_code" widget="ace" options="{'mode': 'python'}" invisible="not use_custom_calc"/>
                        <field name="type_code" />
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
